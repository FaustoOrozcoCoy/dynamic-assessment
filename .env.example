# Application
APP_NAME=Dynamic Assessment API
APP_ENV=development
DEBUG=true

# Database
DATABASE_URL=postgresql+psycopg://dynamic_assessment_user:dynamic_assessment_password@localhost:5432/dynamic_assessment_db

# PostgreSQL Docker configuration
POSTGRES_USER=dynamic_assessment_user
POSTGRES_PASSWORD=dynamic_assessment_password
POSTGRES_DB=dynamic_assessment_db

# Security
SECRET_KEY=change-this-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# OpenRouter / LLM
OPENROUTER_API_KEY=put-your-openrouter-api-key-here
OPENROUTER_MODEL=openai/gpt-4o-mini